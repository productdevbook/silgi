{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "katman": ["./src/index.ts"],
      "katman/*": ["./src/*/index.ts"]
    }
  },
  "include": ["src"]
}
