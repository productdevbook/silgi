    },
    "./client/openapi": {
      "import": "./dist/client/openapi.mjs",
      "types": "./dist/client/openapi.d.mts"
    },
    "./nestjs": {
      "import": "./dist/adapters/nestjs.mjs",
      "types": "./dist/adapters/nestjs.d.mts"
    },
    "./peer": {
      "import": "./dist/adapters/peer.mjs",
      "types": "./dist/adapters/peer.d.mts"
    },
    "./broker": {
      "import": "./dist/broker/index.mjs",
      "types": "./dist/broker/index.d.mts"
    },
    "./broker/nats": {
      "import": "./dist/broker/nats.mjs",
      "types": "./dist/broker/nats.d.mts"
    },
    "./broker/redis": {
      "import": "./dist/broker/redis.mjs",
      "types": "./dist/broker/redis.d.mts"
    },
    "./unstorage": {
      "import": "./lib/unstorage.mjs",
      "types": "./lib/unstorage.d.mts"
    },
    "./ocache": {
      "import": "./lib/ocache.mjs",
      "types": "./lib/ocache.d.mts"
    },
    "./ofetch": {
      "import": "./lib/ofetch.mjs",
      "types": "./lib/ofetch.d.mts"
    },
    "./srvx": {
      "import": "./lib/srvx.mjs",
      "types": "./lib/srvx.d.mts"
    }
  },
  "scripts": {
    "build": "pnpm --filter silgi-analytics-dashboard build && tsdown",
    "build:dashboard": "pnpm --filter silgi-analytics-dashboard build",
    "dev": "vitest",
    "bench": "node --experimental-strip-types bench/update-benchmarks.ts",
    "bench:http": "node --experimental-strip-types bench/http.ts",
    "bench:http:bun": "bun bench/http-bun.ts",
    "bench:memory": "node --expose-gc --experimental-strip-types bench/memory.ts",
    "bench:bun": "bun test/bun-compat.ts",
    "play": "pnpm build && pnpm --filter silgi-playground dev",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt .",
    "fix": "oxlint --fix . && oxfmt .",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "release:beta": "pnpm build && npm publish --tag beta --access public",
    "release": "pnpm build && npm publish --access public",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "crossws": "^0.4.4",
    "defu": "^6.1.4",
    "devalue": "^5.6.4",
    "get-port-please": "^3.2.0",
    "hookable": "^6.1.0",
    "msgpackr": "^1.11.9",
    "ocache": "^0.1.4",
    "ofetch": "2.0.0-alpha.3",
    "ohash": "^2.0.11",
    "srvx": "^0.11.12",
    "unstorage": "^2.0.0-alpha.7"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@nuxt/test-utils": "^4.0.0",
    "@orpc/client": "^1.13.9",
    "@orpc/contract": "^1.13.9",
    "@orpc/server": "^1.13.9",
    "@trpc/client": "^11.14.1",
    "@trpc/server": "^11.14.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "ai": "^6.0.134",
    "elysia": "^1.4.28",
    "express": "^5.2.1",
    "fastify": "^5.8.2",
    "h3": "2.0.1-rc.16",
    "hono": "^4.12.9",
    "ioredis": "^5.10.1",
    "mitata": "^1.0.34",
    "nats": "^2.29.3",
    "nitro": "3.0.260311-beta",
    "nuxt-nightly": "5.0.0-29563820.579db312",
    "obuild": "^0.4.32",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rou3": "^0.8.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@scalar/api-reference": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@scalar/api-reference": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "silgi": "workspace:*"
    }
  }
}
