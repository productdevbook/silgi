{
  "name": "silgi",
  "version": "0.1.0",
  "private": false,
  "description": "The fastest end-to-end type-safe RPC framework for TypeScript — compiled pipelines, single package, every runtime",
  "keywords": [
    "api",
    "client",
    "express",
    "fastify",
    "h3",
    "hono",
    "middleware",
    "msgpack",
    "nextjs",
    "nitro",
    "nuxt",
    "openapi",
    "orpc",
    "react",
    "rpc",
    "server",
    "sveltekit",
    "tanstack-query",
    "trpc",
    "type-safe",
    "typescript",
    "websocket",
    "zod"
  ],
  "homepage": "https://silgi.dev",
  "bugs": {
    "url": "https://github.com/productdevbook/silgi/issues"
  },
  "license": "MIT",
  "author": "productdevbook",
  "repository": {
    "type": "git",
    "url": "https://github.com/productdevbook/silgi.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./client": {
      "import": "./dist/client/index.mjs",
      "types": "./dist/client/index.d.mts"
    },
    "./client/fetch": {
      "import": "./dist/client/adapters/fetch/index.mjs",
      "types": "./dist/client/adapters/fetch/index.d.mts"
    },
    "./client/ofetch": {
      "import": "./dist/client/adapters/ofetch/index.mjs",
      "types": "./dist/client/adapters/ofetch/index.d.mts"
    },
    "./client/plugins": {
      "import": "./dist/client/plugins/index.mjs",
      "types": "./dist/client/plugins/index.d.mts"
    },
    "./msgpack": {
      "import": "./dist/codec/msgpack.mjs",
      "types": "./dist/codec/msgpack.d.mts"
    },
    "./devalue": {
      "import": "./dist/codec/devalue.mjs",
      "types": "./dist/codec/devalue.d.mts"
    },
    "./ws": {
      "import": "./dist/ws.mjs",
      "types": "./dist/ws.d.mts"
    },
    "./zod": {
      "import": "./dist/integrations/zod/index.mjs",
      "types": "./dist/integrations/zod/index.d.mts"
    },
    "./tanstack-query": {
      "import": "./dist/integrations/tanstack-query/index.mjs",
      "types": "./dist/integrations/tanstack-query/index.d.mts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.mjs",
      "types": "./dist/plugins/index.d.mts"
    },
    "./cache": {
      "import": "./dist/plugins/cache.mjs",
      "types": "./dist/plugins/cache.d.mts"
    },
    "./cors": {
      "import": "./dist/plugins/cors.mjs",
      "types": "./dist/plugins/cors.d.mts"
    },
    "./otel": {
      "import": "./dist/plugins/otel.mjs",
      "types": "./dist/plugins/otel.d.mts"
    },
    "./pino": {
      "import": "./dist/plugins/pino.mjs",
      "types": "./dist/plugins/pino.d.mts"
    },
    "./ratelimit": {
      "import": "./dist/plugins/ratelimit.mjs",
      "types": "./dist/plugins/ratelimit.d.mts"
    },
    "./ai": {
      "import": "./dist/integrations/ai/index.mjs",
      "types": "./dist/integrations/ai/index.d.mts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.mjs",
      "types": "./dist/adapters/fastify.d.mts"
    },
    "./contract": {
      "import": "./dist/contract.mjs",
      "types": "./dist/contract.d.mts"
    },
    "./react": {
      "import": "./dist/integrations/react/index.mjs",
      "types": "./dist/integrations/react/index.d.mts"
    },
    "./client/server": {
      "import": "./dist/client/server.mjs",
      "types": "./dist/client/server.d.mts"
    },
    "./cookies": {
      "import": "./dist/plugins/cookies.mjs",
      "types": "./dist/plugins/cookies.d.mts"
    },
    "./h3": {
      "import": "./dist/adapters/h3.mjs",
      "types": "./dist/adapters/h3.d.mts"
    },
    "./hono": {
      "import": "./dist/adapters/hono.mjs",
      "types": "./dist/adapters/hono.d.mts"
    },
    "./express": {
      "import": "./dist/adapters/express.mjs",
      "types": "./dist/adapters/express.d.mts"
    },
    "./nitro": {
      "import": "./dist/adapters/nitro.mjs",
      "types": "./dist/adapters/nitro.d.mts"
    },
    "./aws-lambda": {
      "import": "./dist/adapters/aws-lambda.mjs",
      "types": "./dist/adapters/aws-lambda.d.mts"
    },
    "./elysia": {
      "import": "./dist/adapters/elysia.mjs",
      "types": "./dist/adapters/elysia.d.mts"
    },
    "./nextjs": {
      "import": "./dist/adapters/nextjs.mjs",
      "types": "./dist/adapters/nextjs.d.mts"
    },
    "./sveltekit": {
      "import": "./dist/adapters/sveltekit.mjs",
      "types": "./dist/adapters/sveltekit.d.mts"
    },
    "./trpc": {
      "import": "./dist/trpc-interop.mjs",
      "types": "./dist/trpc-interop.d.mts"
    },
    "./tanstack-query/ssr": {
      "import": "./dist/integrations/tanstack-query/ssr.mjs",
      "types": "./dist/integrations/tanstack-query/ssr.d.mts"
    },
    "./remix": {
      "import": "./dist/adapters/remix.mjs",
      "types": "./dist/adapters/remix.d.mts"
    },
    "./astro": {
      "import": "./dist/adapters/astro.mjs",
      "types": "./dist/adapters/astro.d.mts"
    },
    "./solidstart": {
      "import": "./dist/adapters/solidstart.mjs",
      "types": "./dist/adapters/solidstart.d.mts"
    },
    "./message-port": {
      "import": "./dist/adapters/message-port.mjs",
      "types": "./dist/adapters/message-port.d.mts"
    },
    "./client/openapi": {
      "import": "./dist/client/openapi.mjs",
      "types": "./dist/client/openapi.d.mts"
    },
    "./nestjs": {
      "import": "./dist/adapters/nestjs.mjs",
      "types": "./dist/adapters/nestjs.d.mts"
    },
    "./peer": {
      "import": "./dist/adapters/peer.mjs",
      "types": "./dist/adapters/peer.d.mts"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "vitest",
    "bench": "node --experimental-strip-types bench/update-benchmarks.ts",
    "bench:memory": "node --expose-gc --experimental-strip-types bench/memory.ts",
    "bench:bun": "bun test/bun-compat.ts",
    "play": "pnpm build && pnpm --filter silgi-playground dev",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt .",
    "fix": "oxlint --fix . && oxfmt .",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "crossws": "^0.4.4",
    "defu": "^6.1.4",
    "devalue": "^5.6.4",
    "get-port-please": "^3.2.0",
    "hookable": "^6.1.0",
    "msgpackr": "^1.11.9",
    "ocache": "^0.1.2",
    "ofetch": "2.0.0-alpha.3",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@orpc/client": "^1.13.8",
    "@orpc/contract": "^1.13.8",
    "@orpc/server": "^1.13.8",
    "@trpc/client": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "ai": "^6.0.116",
    "elysia": "^1.4.28",
    "express": "^5.2.1",
    "fastify": "^5.8.2",
    "h3": "2.0.1-rc.16",
    "hono": "^4.12.8",
    "mitata": "^1.0.34",
    "nuxt-nightly": "5.0.0-29563820.579db312",
    "obuild": "^0.4.32",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rou3": "^0.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@scalar/api-reference": ">=1.0.0",
    "unstorage": ">=2.0.0-alpha.7"
  },
  "peerDependenciesMeta": {
    "@scalar/api-reference": {
      "optional": true
    },
    "unstorage": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "silgi": "workspace:*"
    }
  }
}
