{
  "name": "katman",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "The fastest end-to-end type-safe RPC framework — 5x faster than oRPC, 6x less memory",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./client": "./src/client/index.ts",
    "./client/fetch": "./src/client/adapters/fetch/index.ts",
    "./client/plugins": "./src/client/plugins/index.ts",
    "./contract": "./src/contract/index.ts",
    "./node": "./src/server/adapters/node/index.ts",
    "./fetch": "./src/server/adapters/fetch/index.ts",
    "./fastify": "./src/server/adapters/fastify/index.ts",
    "./websocket": "./src/server/adapters/websocket/index.ts",
    "./plugins": "./src/server/plugins/index.ts",
    "./openapi": "./src/openapi/index.ts",
    "./zod": "./src/integrations/zod/index.ts",
    "./tanstack-query": "./src/integrations/tanstack-query/index.ts",
    "./react": "./src/integrations/react/index.ts",
    "./otel": "./src/plugins/otel/index.ts",
    "./pino": "./src/plugins/pino/index.ts",
    "./ratelimit": "./src/plugins/ratelimit/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "vitest",
    "bench": "node --experimental-strip-types bench/update-benchmarks.ts",
    "bench:orpc": "node --experimental-strip-types bench/vs-orpc.ts",
    "bench:h3": "node --experimental-strip-types bench/vs-h3.ts",
    "bench:http": "node --experimental-strip-types bench/http.ts",
    "bench:micro": "node --experimental-strip-types bench/micro.ts",
    "bench:pipeline": "node --experimental-strip-types bench/pipeline.ts",
    "play": "node --experimental-strip-types playground/v2-server.ts",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "@orpc/client": "^1.13.7",
    "@orpc/contract": "^1.13.7",
    "@orpc/server": "^1.13.7",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "h3": "2.0.1-rc.16",
    "mitata": "^1.0.34",
    "obuild": "^0.4.32",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
