    },
    "./ratelimit": {
      "import": "./dist/plugins/ratelimit.mjs",
      "types": "./dist/plugins/ratelimit.d.mts"
    },
    "./ai": {
      "import": "./dist/integrations/ai/index.mjs",
      "types": "./dist/integrations/ai/index.d.mts"
    },
    "./better-auth": {
      "import": "./dist/integrations/better-auth/index.mjs",
      "types": "./dist/integrations/better-auth/index.d.mts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.mjs",
      "types": "./dist/adapters/fastify.d.mts"
    },
    "./contract": {
      "import": "./dist/contract.mjs",
      "types": "./dist/contract.d.mts"
    },
    "./react": {
      "import": "./dist/integrations/react/index.mjs",
      "types": "./dist/integrations/react/index.d.mts"
    },
    "./client/server": {
      "import": "./dist/client/server.mjs",
